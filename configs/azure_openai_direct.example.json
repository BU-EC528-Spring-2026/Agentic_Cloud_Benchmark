{
  "azure_openai": {
    "api_key": "",
    "api_key_env": "AZURE_OPENAI_API_KEY",
    "model": "gpt-4.1-mini",
    "base_url": "https://<resource>.openai.azure.com/openai/v1/"
  },
  "agent": {
    "agent_config": "configs/agents/azure_openai.example.json",
    "max_steps": 25,
    "keep_artifacts": true
  },
  "runs": [
    {
      "name": "local",
      "manifest": "manifests/local_suite.json",
      "output": "runs/local_azure_openai_agent_eval.json"
    },
    {
      "name": "github",
      "manifest": "manifests/github_openclaw_extended.json",
      "output": "runs/github_openclaw_extended_azure_openai_agent_eval.json"
    }
  ],
  "summary_output": "runs/azure_openai_agent_batch_summary.json"
}
