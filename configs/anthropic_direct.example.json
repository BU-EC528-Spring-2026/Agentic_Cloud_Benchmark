{
  "anthropic": {
    "api_key": "",
    "api_key_env": "ANTHROPIC_API_KEY",
    "model": "claude-sonnet-4-20250514",
    "base_url": "https://api.anthropic.com",
    "version": "2023-06-01"
  },
  "agent": {
    "ops_agent_ref": "acbench.agents.anthropic_ops:AnthropicOpsAgent",
    "code_agent_ref": "acbench.agents.anthropic_code:AnthropicCodePatchAgent",
    "max_steps": 25,
    "keep_artifacts": true
  },
  "runs": [
    {
      "name": "local",
      "manifest": "manifests/local_suite.json",
      "output": "runs/local_anthropic_agent_eval.json"
    },
    {
      "name": "github",
      "manifest": "manifests/github_openclaw_extended.json",
      "output": "runs/github_openclaw_extended_anthropic_agent_eval.json"
    }
  ],
  "summary_output": "runs/anthropic_agent_batch_summary.json"
}
